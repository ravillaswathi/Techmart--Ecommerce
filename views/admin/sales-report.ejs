<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Sales Report | TechMart</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
    background:#f4f6f9;
}

.card{
    border:none;
    border-radius:12px;
    box-shadow:0 5px 15px rgba(0,0,0,.08);
}

.table th{
    background:#0d6efd;
    color:#fff;
}

.table td{
    vertical-align:middle;
}

</style>

</head>

<body>

<div class="container py-5">

<div class="d-flex justify-content-between align-items-center mb-4">

<h2>📊 Sales Report</h2>

<div>

<a href="/admin/dashboard" class="btn btn-secondary">

← Dashboard

</a>

<a href="/admin/sales-report/excel"
class="btn btn-success">

📥 Export Excel

</a>

</div>

</div>

<%

let totalRevenue = 0;

reports.forEach(report=>{

    totalRevenue += Number(report.total_amount);

});

%>

<div class="row mb-4">

<div class="col-md-6">

<div class="card text-center p-4">

<h5>Total Orders</h5>

<h2 class="text-primary">

<%= reports.length %>

</h2>

</div>

</div>

<div class="col-md-6">

<div class="card text-center p-4">

<h5>Total Revenue</h5>

<h2 class="text-success">

₹ <%= totalRevenue %>

</h2>

</div>

</div>

</div>

<div class="card">

<div class="card-body">

<table class="table table-bordered table-hover">

<thead>

<tr>

<th>Order ID</th>

<th>Customer</th>

<th>Amount</th>

<th>Payment</th>

<th>Status</th>

<th>Date</th>

</tr>

</thead>

<tbody>

<% reports.forEach(report=>{ %>

<tr>

<td>

#<%= report.order_id %>

</td>

<td>

<%= report.name %>

</td>

<td class="fw-bold text-success">

₹ <%= report.total_amount %>

</td>

<td>

<%= report.payment_method %>

</td>

<td>

<%

let badge="secondary";

if(report.status=="Pending") badge="warning";

else if(report.status=="Processing") badge="info";

else if(report.status=="Shipped") badge="primary";

else if(report.status=="Delivered") badge="success";

else if(report.status=="Cancelled") badge="danger";

%>

<span class="badge bg-<%= badge %>">

<%= report.status %>

</span>

</td>

<td>

<%= new Date(report.order_date).toLocaleDateString() %>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</div>

</div>

</body>

</html>