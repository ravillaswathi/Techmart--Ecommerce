<!DOCTYPE html>
<html>
<head>

<title>Customer Management</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-5">

<h2 class="mb-4">Customer Management</h2>

<div class="card shadow p-4">

<form action="/admin/customers/add" method="POST">

<div class="row">

<div class="col-md-6 mb-3">

<label>Name</label>

<input
type="text"
name="name"
class="form-control"
required>

</div>

<div class="col-md-6 mb-3">

<label>Email</label>

<input
type="email"
name="email"
class="form-control"
required>

</div>

<div class="col-md-6 mb-3">

<label>Phone</label>

<input
type="text"
name="phone"
class="form-control"
required>

</div>

<div class="col-md-6 mb-3">

<label>Address</label>

<textarea
name="address"
class="form-control"
rows="1"
required></textarea>

</div>

</div>

<button class="btn btn-success">
Add Customer
</button>

<a href="/admin/dashboard" class="btn btn-secondary">
Back
</a>

</form>

<hr>

<h3>Customer List</h3>

<input
type="text"
id="searchCustomer"
class="form-control mb-3"
placeholder="Search Customer">

<table class="table table-bordered table-hover">

<thead class="table-dark">

<tr>

<th>ID</th>
<th>Name</th>
<th>Email</th>
<th>Phone</th>
<th>Address</th>
<th>Action</th>

</tr>

</thead>

<tbody>

<% customers.forEach(customer=>{ %>

<tr>

<td><%= customer.customer_id %></td>

<td><%= customer.name %></td>

<td><%= customer.email %></td>

<td><%= customer.phone %></td>

<td><%= customer.address %></td>

<td>

<a
href="/admin/customers/edit/<%= customer.customer_id %>"
class="btn btn-warning btn-sm">

Edit

</a>

<a
href="/admin/customers/delete/<%= customer.customer_id %>"
onclick="return confirm('Delete Customer?')"
class="btn btn-danger btn-sm">

Delete

</a>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</div>

<script>

const search=document.getElementById("searchCustomer");

search.addEventListener("keyup",()=>{

const filter=search.value.toLowerCase();

const rows=document.querySelectorAll("tbody tr");

rows.forEach(row=>{

const text=row.innerText.toLowerCase();

row.style.display=text.includes(filter)?"":"none";

});

});

</script>

</body>
</html>