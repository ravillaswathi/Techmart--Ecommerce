<!DOCTYPE html>
<html>
<head>

    <title>Order Management</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-4">

    <h2 class="mb-4">Order Management</h2>

    <!-- Add Order Card -->
    <div class="card shadow mb-4">

        <div class="card-header bg-primary text-white">
            Create New Order
        </div>

        <div class="card-body">

            <form action="/admin/orders/add" method="POST">

                <div class="row">

                    <!-- Customer -->
                    <div class="col-md-4 mb-3">

                        <label class="form-label">Customer</label>

                        <select name="customer_id" class="form-select" required>

                            <option value="">Select Customer</option>

                            <% customers.forEach(customer => { %>

                                <option value="<%= customer.customer_id %>">
                                    <%= customer.name %>
                                </option>

                            <% }) %>

                        </select>

                    </div>

                    <!-- Product -->
                    <div class="col-md-4 mb-3">

                        <label class="form-label">Product</label>

                        <select
                            name="product_id"
                            id="product"
                            class="form-select"
                            required>

                            <option value="">Select Product</option>

                            <% products.forEach(product => { %>

                                <option
                                    value="<%= product.product_id %>"
                                    data-price="<%= product.price %>">

                                    <%= product.product_name %>
                                    (₹<%= product.price %>)

                                </option>

                            <% }) %>

                        </select>

                    </div>

                    <!-- Quantity -->
                    <div class="col-md-2 mb-3">

                        <label class="form-label">Quantity</label>

                        <input
                            type="number"
                            name="quantity"
                            id="qty"
                            class="form-control"
                            min="1"
                            value="1"
                            required>

                    </div>

                    <!-- Total -->
                    <div class="col-md-2 mb-3">

                        <label class="form-label">Total</label>

                        <input
                            type="text"
                            id="total"
                            class="form-control"
                            readonly>

                    </div>

                </div>
                <div class="col-md-3 mb-3">

    <label class="form-label">Order Status</label>

    <select name="status" class="form-select" required>

        <option value="Pending">Pending</option>
        <option value="Processing">Processing</option>
        <option value="Shipped">Shipped</option>
        <option value="Delivered">Delivered</option>

    </select>

</div>
                <button class="btn btn-success">
                    Save Order
                </button>

            </form>

        </div>

    </div>

    <!-- Order List -->

    <div class="card shadow">

        <div class="card-header bg-dark text-white">
            Order List
        </div>

        <div class="card-body">

            <table class="table table-bordered table-hover">

                <thead class="table-dark">

                    <tr>

                        <th>ID</th>
                        <th>Customer</th>
                        <th>Date</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Action</th>

                    </tr>

                </thead>

                <tbody>

                <% orders.forEach((order, index) => { %>

                    <tr>

                        <td><%= index + 1 %></td>

                        <td><%= order.customer_name %></td>

                        <td><%= order.order_date %></td>

                        <td>₹ <%= order.total_amount %></td>

                        <td>

<td>

<form action="/admin/orders/status/<%= order.order_id %>" method="POST">

<select
    name="status"
    class="form-select form-select-sm"
    onchange="this.form.submit()">

<option value="Pending" <%= order.status=="Pending"?"selected":"" %>>Pending</option>

<option value="Processing" <%= order.status=="Processing"?"selected":"" %>>Processing</option>

<option value="Shipped" <%= order.status=="Shipped"?"selected":"" %>>Shipped</option>

<option value="Delivered" <%= order.status=="Delivered"?"selected":"" %>>Delivered</option>

<option value="Cancelled" <%= order.status=="Cancelled"?"selected":"" %>>Cancelled</option>

</select>


</form>

</td>

                        <td>

                            <a
                                href="/admin/orders/edit/<%= order.order_id %>"
                                class="btn btn-warning btn-sm">

                                Edit

                            </a>

                            <a
                                href="/admin/orders/delete/<%= order.order_id %>"
                                class="btn btn-danger btn-sm"
                                onclick="return confirm('Delete this order?')">

                                Delete

                            </a>

                        </td>

                    </tr>

                <% }) %>

                </tbody>

            </table>

        </div>

    </div>

</div>

<script>

const product = document.getElementById("product");
const qty = document.getElementById("qty");
const total = document.getElementById("total");

function calculateTotal(){

    const option = product.options[product.selectedIndex];

    const price = Number(option.getAttribute("data-price")) || 0;

    const quantity = Number(qty.value);

    total.value = price * quantity;

}

product.addEventListener("change", calculateTotal);

qty.addEventListener("input", calculateTotal);

</script>

</body>
</html>