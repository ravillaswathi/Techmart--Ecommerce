<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Cart | TechMart</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body{
            background:#f5f7fa;
        }

        .cart-card{
            border:none;
            border-radius:15px;
            box-shadow:0 5px 15px rgba(0,0,0,.08);
        }

        .summary-card{
            border:none;
            border-radius:15px;
            box-shadow:0 5px 15px rgba(0,0,0,.08);
            position:sticky;
            top:20px;
        }

        .product-img{
            width:120px;
            height:120px;
            object-fit:contain;
            background:#fff;
            border:1px solid #ddd;
            border-radius:10px;
            padding:8px;
        }

        .qty-btn{
            width:35px;
            height:35px;
            padding:0;
        }

        .price{
            font-size:22px;
            font-weight:bold;
            color:#198754;
        }
    </style>
</head>

<body>

<%- include("partials/navbar") %>

<%
let total = 0;

cartItems.forEach(item=>{
    total += item.price * item.quantity;
});
%>

<div class="container py-5">

    <h2 class="fw-bold mb-4">
        🛒 My Cart
    </h2>

    <div class="row">

        <!-- Cart Items -->

        <div class="col-lg-8">

            <div class="card cart-card">

                <div class="card-body">

                    <% if(cartItems.length==0){ %>

                        <div class="text-center py-5">

                            <h3 class="text-muted">
                                Your Cart is Empty
                            </h3>

                            <a href="/customer/home" class="btn btn-primary mt-3">
                                Continue Shopping
                            </a>

                        </div>

                    <% } else { %>

                        <% cartItems.forEach(item=>{ %>

                        <div class="row align-items-center border-bottom py-4">

                            <!-- Image -->

                            <div class="col-md-2 text-center">

                                <img
                                    src="/uploads/products/<%= item.image %>"
                                    class="product-img"
                                    alt="<%= item.product_name %>">

                            </div>

                            <!-- Product Details -->

                            <div class="col-md-5">

                                <h5 class="fw-bold">
                                    <%= item.product_name %>
                                </h5>

                                <p class="text-muted mb-2">
                                    Brand :
                                    <%= item.brand %>
                                </p>

                                <div class="price">
                                    ₹ <%= item.price %>
                                </div>

                            </div>

                            <!-- Quantity -->

                            <div class="col-md-2 text-center">

                                <small class="text-muted">
                                    Quantity
                                </small>

                                <div class="d-flex justify-content-center align-items-center mt-2">

                                    <form action="/customer/cart/decrease/<%= item.cart_id %>" method="POST">

                                        <button class="btn btn-outline-secondary qty-btn">
                                            −
                                        </button>

                                    </form>

                                    <span class="mx-3 fw-bold">
                                        <%= item.quantity %>
                                    </span>

                                    <form action="/customer/cart/increase/<%= item.cart_id %>" method="POST">

                                        <button class="btn btn-outline-primary qty-btn">
                                            +
                                        </button>

                                    </form>

                                </div>

                            </div>

                            <!-- Total Price -->

                            <div class="col-md-3 text-end">

                                <h5 class="text-success fw-bold">
                                    ₹ <%= item.price * item.quantity %>
                                </h5>

                                <form
                                    action="/customer/cart/remove/<%= item.cart_id %>"
                                    method="POST"
                                    class="mt-3">

                                    <button class="btn btn-outline-danger btn-sm">
                                        🗑 Remove
                                    </button>

                                </form>

                            </div>

                        </div>

                        <% }) %>

                    <% } %>

                </div>

            </div>

        </div>

        <!-- Order Summary -->

        <div class="col-lg-4">

            <div class="card summary-card">

                <div class="card-body">

                    <h3 class="mb-3">
                        Order Summary
                    </h3>

                    <hr>

                    <div class="d-flex justify-content-between">

                        <span>Items</span>

                        <strong>
                            <%= cartItems.length %>
                        </strong>

                    </div>

                    <hr>

                    <div class="d-flex justify-content-between">

                        <span>Total Amount</span>

                        <h5 class="text-success">
                            ₹ <%= total %>
                        </h5>

                    </div>

                    <hr>

                    <% if(cartItems.length>0){ %>

                    <a
                        href="/customer/order-summary"
                        class="btn btn-success w-100">

                        📋 Proceed to Order Summary

                    </a>

                    <% } %>

                </div>

            </div>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>