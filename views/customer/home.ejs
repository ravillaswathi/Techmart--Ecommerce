<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>TechMart</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">

<style>

body{
    background:#f8f9fa;
}

.card{
    border:none;
    border-radius:15px;
    overflow:hidden;
    transition:.3s;
}

.card:hover{
    transform:translateY(-5px);
    box-shadow:0 10px 25px rgba(0,0,0,.2);
}

.card img{
    height:220px;
    object-fit:cover;
}

.price{
    color:green;
    font-size:26px;
    font-weight:bold;
}

.banner{
    background:linear-gradient(90deg,#0d6efd,#6610f2);
    color:white;
    border-radius:15px;
    padding:50px;
    margin-bottom:40px;
}

</style>

</head>

<body>

<%- include("partials/navbar") %>

<div class="container mt-4">

    <!-- Banner -->

    <div class="banner">

        <h1>🔥 TechMart Mega Sale</h1>

        <h3>Up to 70% OFF on Electronics</h3>

        <a href="/customer/home" class="btn btn-warning mt-3">
    Shop Now
</a>

    </div>

    <h2 class="mb-4 fw-bold">

        Featured Products

    </h2>

    <div class="row">

        <% products.forEach(product=>{ %>

        <div class="col-lg-3 col-md-4 col-sm-6 mb-4">

            <div class="card h-100 shadow">

                <a href="/customer/product/<%= product.product_id %>">
    <img src="/uploads/products/<%= product.image %>" class="card-img-top">
</a>

                <div class="card-body">

                    <h5 class="card-title">
    <a href="/customer/product/<%= product.product_id %>"
       class="text-decoration-none text-dark">
        <%= product.product_name %>
    </a>
</h5>

                    <p class="text-muted">

                        <%= product.brand %>

                    </p>

                    <div class="price">

                        ₹ <%= product.price %>

                    </div>

                    <small>

                        Stock :
                        <%= product.stock %>

                    </small>

                </div>

                <div class="card-footer bg-white">

                    <!-- Add To Cart -->

                    <form
                    action="/customer/cart/add/<%= product.product_id %>"
                    method="POST">

                        <button
                        type="submit"
                        class="btn btn-primary w-100 mb-2">

                            <i class="fa-solid fa-cart-shopping"></i>

                            Add To Cart

                        </button>

                    </form>

                    <!-- Wishlist -->

                    <form
                    action="/customer/wishlist/add/<%= product.product_id %>"
                    method="POST">

                        <button
                        type="submit"
                        class="btn btn-outline-danger w-100">

                            <i class="fa-solid fa-heart"></i>

                            Wishlist

                        </button>

                    </form>

                </div>

            </div>

        </div>

        <% }) %>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>