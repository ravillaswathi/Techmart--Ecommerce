<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>TechMart</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Segoe UI',sans-serif;
}

body{

height:100vh;

background:linear-gradient(135deg,#0f2027,#203a43,#2c5364);

display:flex;

justify-content:center;

align-items:center;

overflow:hidden;

}

.card-box{

width:470px;

background:white;

padding:45px;

border-radius:20px;

box-shadow:0 20px 45px rgba(0,0,0,.35);

animation:fade .8s;

}

@keyframes fade{

from{

opacity:0;
transform:translateY(30px);

}

to{

opacity:1;
transform:translateY(0);

}

}

.logo{

font-size:60px;

color:#0d6efd;

margin-bottom:10px;

}

h1{

font-weight:bold;

margin-bottom:5px;

}

p{

color:gray;

margin-bottom:35px;

}

.btn{

height:55px;

font-size:20px;

border-radius:12px;

margin-bottom:18px;

transition:.3s;

}

.btn:hover{

transform:scale(1.04);

}

.footer{

margin-top:25px;

font-size:14px;

color:gray;

}

</style>

</head>

<body>

<div class="card-box text-center">

<div class="logo">
<i class="fas fa-cart-shopping"></i>
</div>

<h1>TechMart</h1>

<p>E-Commerce Management System</p>

<a href="/admin/login" class="btn btn-dark w-100">
<i class="fas fa-user-shield"></i>
&nbsp;
Admin Login
</a>

<a href="/customer/login" class="btn btn-primary w-100">
<i class="fas fa-user"></i>
&nbsp;
Customer Login
</a>

<a href="/customer/signup" class="btn btn-success w-100">
<i class="fas fa-user-plus"></i>
&nbsp;
Customer Signup
</a>

<div class="footer">

© 2026 TechMart 

</div>

</div>

</body>
</html>